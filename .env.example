# Django cryptographic signing key
SECRET_KEY=your-secret-key-at-least-50-chars-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Enable Django debug mode (True/False)
DEBUG=True

# Comma-separated list of host/domain names Django accepts requests from
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=21001
POSTGRES_DB=drf_celery_tutorial
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# User email verification token lifetime in seconds
EMAIL_VERIFICATION_TOKEN_LIFETIME=300
